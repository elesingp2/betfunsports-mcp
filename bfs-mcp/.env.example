# ── Telegram Bot (only needed for bfs-bot) ──
BFS_TG_TOKEN=your_telegram_bot_token
BFS_LLM_KEY=your_openrouter_api_key
BFS_LLM_BASE=https://openrouter.ai/api/v1      # or any OpenAI-compatible endpoint
BFS_LLM_MODEL=deepseek/deepseek-chat             # cheap: ~$0.0002/request
BFS_MAX_HISTORY=30                                # conversation memory
BFS_MAX_ITER=8                                    # max tool-call iterations per message
